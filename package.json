{
    "name": "Scriptsmon",
    "publisher": "yigal",
    "version": "1.11.0",
    "description": "",
    "license": "ISC",
    "author": "",
    "type": "module",
    "main": "dist/extension.js",
    "types": "types/src/extension.d.ts",
    "repository": "https://github.com/yigalirani/scriptsmon.git",
    "scripts": {
        "test": "node ./dist/test.js",
        "build": "node build.ts",
        "tsc": "tsc",
        "eslint": "eslint . --color --max-warnings=0",
        "ls": "ls -la  --color=always",
        "compile": "npm run build & cd client & npm run build",
        "vscode:prepublish": "npm run compile",
        "oxlinttypeaware": "oxlint . --type-aware",
        "oxlint": "oxlint ", 
        "biome": "biome lint",
        "vsce": "vsce package"
    },
    "workspaces": [
        "client"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "scriptsmon": {
        "build": [
            "src",
            "package.json",
            "build.ts"
        ],
        "eslint,tsc": [
            "$build",
            "client/src",
            "tsconfig.json",
            "eslint.config.mjs"
        ],
        "test": "./dist/test.js",
        "oxlint,oxlinttypeaware": [
            "$eslint",
            ".oxlintrc.json"
        ],
        "biome": [
            "$eslint",
            "biome.json"
        ],
        "ls": [
            "."
        ],
        "#dev": [
            "eslint",
            "tsc",
            "oxlinttypeaware",
            "biome"
        ]
    },
    "keywords": [],
    "contributes": {
        "commands": [
            {
                "command": "Scriptsmon.start",
                "title": "Scriptsmon: start"
            },
            {
                "command": "Scriptsmon.runner.play",
                "title": "Play",
                "icon": "$(play)"
            }, 
            {
                "command": "Scriptsmon.runner.debug",
                "title": "Debug",
                "icon": "$(debug)"
            },
            {
                "command": "Scriptsmon.webview.open",
                "title": "Open Webview"
            },
            {
                "command": "Scriptsmon.startWatching",
                "title": "Start Watching"
            },
            {
                "command": "Scriptsmon.toggleDumpDebug",
                "title": "Toggle Dump Debug"
            }
        ],
        "menus": {
            "view/item/context": [
                {
                    "command": "Scriptsmon.runner.play",
                    "when": "view == Scriptsmon.tree && viewItem == 'runner'",
                    "group": "inline"
                },
                {
                    "command": "Scriptsmon.runner.debug",
                    "when": "view == Scriptsmon.tree && viewItem == 'runner'",
                    "group": "inline"
                }
            ]
        },
        "viewsContainers": {
            "panel": [
                {
                    "id": "scriptsmon-bottom-drawer",
                    "title": "Scriptsmon Terminals",
                    "icon": "$(terminal)"
                }
            ]
        },
        "views": {
            "scriptsmon-bottom-drawer": [
                {
                    "type": "webview",
                    "id": "Scriptsmon.webview",
                    "name": "Scriptsmon web view2"
                }
            ]
        }
    },
    "engines": {
        "vscode": "^1.100.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.5",
        "@eslint/js": "^9",
        "@types/lodash.clonedeep": "^4.5.9",
        "@types/node": "25.3.3",
        "@types/vscode": "^1.100",
        "esbuild": "0.27.3",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-import-x": "4.16.1",
        "oxlint": "^1.51.0",
        "typescript": "5.9.3",
        "typescript-eslint": "8.56.1"
    },
    "dependencies": {
        "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
        "@yigal/base_types": "file:../base_types",
        "acorn": "^8.16.0",
        "chokidar": "^5.0.0",
        "eslint": "^9",
        "globals": "^17.4.0",
        "lodash.clonedeep": "^4.5.0"
    }
}
